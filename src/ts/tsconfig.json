{
    "extends": "@maddimathon/build-utilities/tsconfig",
    "include": [
        "../../src/ts/**/*",
        "./src/ts/**/*"
    ],
    "exclude": [
        "./node_modules/**/*"
    ],
    "compilerOptions": {
        "declaration": true,
        "declarationMap": false,
        "isolatedModules": false,
        "outDir": "../../dist/ts/",
        "rootDir": "./",
        "sourceMap": false,
        "verbatimModuleSyntax": true
    }
}