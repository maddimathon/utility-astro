---
/**
 * @since 0.1.0-alpha
 *
 * @packageDocumentation
 */

/* import - types */
import type { GenericElementProps } from '../../ts/types/index.js';
import type { CodeBlockProps } from '../../astro/components/CodeBlock.astro';

/* import - functions */

/* import - values */

/* import - components */
import CodeBlock from '../../astro/components/CodeBlock.astro';
import Toggle, { type ToggleProps } from '../../astro/components/Toggle.astro';
import { slugify } from '@maddimathon/utility-typescript';
import type { PartialExcept } from '@maddimathon/utility-typescript/types';

/* import - layouts */

/* TYPES ===================================== */

/* PROPS ===================================== */

export type Props_Inner = {
    title: string;

    code?: string;

    heading?: number;
    lang?: Required<CodeBlockProps>['lang'];

    /**
     * @since ___PKG_VERSION___
     */
    ToggleComponent?: (
        props: PartialExcept<ToggleProps, 'children' | 'id'>,
    ) => any;

    /**
     * @since ___PKG_VERSION___
     */
    toggleProps?: {};
};

export interface Props extends GenericElementProps<Props_Inner, 'div'> {}

const {
    lang,
    code,
    heading = 2,
    title,
    ToggleComponent = Toggle,
    toggleProps = {},
} = Astro.props.frontmatter ?? Astro.props;

/* CONSTANTS ===================================== */

const html: string = (await Astro.slots.render('default'))?.trim();

const id = slugify(`toggle-dump-${title}`);
---

<ToggleComponent
    {...toggleProps}
    heading={heading}
    id={id}
>
    <Fragment
        slot='button'
        set:text={title}
    />
    {
        code ? (
            <CodeBlock
                lang={lang}
                children={code.trim()}
            />
        ) : (
            <Fragment set:html={html.trim()} />
        )
    }
</ToggleComponent>
