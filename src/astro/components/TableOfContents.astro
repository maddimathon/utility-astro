---
/**
 * @since 0.1.0-alpha.7
 *
 * @packageDocumentation
 */

/* import - types */
import type { PartialExcept } from '@maddimathon/utility-typescript/types';
import type { GenericElementProps } from '../../ts/types/index.js';
import type { MenuItem } from './MenuList.astro';
import type { NavMenuProps } from './NavMenu.astro';
import type { ToggleProps } from './Toggle.astro';

/* import - functions */
import MenuList from './MenuList.astro';
import { parseMenuItem } from './NavMenu.astro';

/* import - values */

/* import - components */
import Heading from './Heading.astro';
import Toggle from './Toggle.astro';

/* import - layouts */

/* TYPES ===================================== */

/* PROPS ===================================== */

type NavMenu_PartialKeys = 'id';

type NavMenu_SemiProps = Omit<
    NavMenuProps,
    NavMenu_PartialKeys | 'aria-label' | 'aria-labelledby'
> & Partial<Pick<NavMenuProps, NavMenu_PartialKeys>>;

/**
 * Input props for the TableOfContents component.
 *
 * @since 0.1.0-alpha.7
 * @since ___PKG_VERSION___ — Renamed from TableOfContents_Props to TableOfContentsProps.
 */
export interface TableOfContentsProps extends NavMenu_SemiProps {
    /**
     * The base heading level for this TOC.
     */
    heading: number;

    /**
     * Whether the table of contents should be in a Toggle component.
     *
     * @default true
     */
    asToggle?: boolean|undefined;
    
    convertHrefStringsToAbsolute?: boolean | undefined;

    defaultOpen?: boolean|undefined;

    /**
     * The base display heading level for this TOC, if any.
     * 
     * @default undefined
     */
    displayHeading?: number | undefined;

    /**
     * @since ___PKG_VERSION___
     */
    ToggleComponent?: ( props: PartialExcept<ToggleProps,  'children'|'id' > ) => any;
        
    /**
     * @since ___PKG_VERSION___
     */
    toggleProps?: {};
}

type Props = GenericElementProps<TableOfContentsProps, 'div', 'aria-label' | 'aria-labelledby'>;

const {
    asToggle = true,
    class: classList = [],
    convertHrefStringsToAbsolute,
    defaultOpen,
    displayHeading,
    heading,
    id = 'toc',
    menu,
    ToggleComponent = Toggle,
    toggleProps = {},
    ...attributes
}: Props = Astro.props.frontmatter ?? Astro.props;

/* FUNCTIONS ===================================== */

export function parseTableOfContents(
    currentURL: URL,
    item: TableOfContentsProps['menu'][number],
    convertHrefStringsToAbsolutePath: boolean | null = null,
): MenuItem {
    return parseMenuItem(currentURL, item, convertHrefStringsToAbsolutePath);

    // const asMenuItem = parseMenuItem(currentURL, item, convertHrefStringsToAbsolutePath);

    // const html_attrs = parseItemAttributes(asMenuItem);

    // const html = html_attrs.href
    //     ? `<a${htmlAttributeString({
    //         ...html_attrs,
    //         href: item.href instanceof URL ? item.href.toString() : item.href,
    //         child: undefined,
    //     })}>${html_attrs.html}</a>`
    //     : `<span>${html_attrs.html}</span>`;

    // if (!asMenuItem.child?.length) {
    //     return { html };
    // }

    // const children = item.child?.map(_childItem =>parseTableOfContents(currentURL, _childItem));

    // return {
    //     html,
    //     children,
    //     childrenTag: 'ol',
    // };
}

/* CONSTANTS ===================================== */

const headingID = `${id}---heading-element`;

const nestedLists = menu.map(item =>parseTableOfContents(Astro.url, item, convertHrefStringsToAbsolute));

const headingHTML = (await Astro.slots.render('button'))?.trim() || 'Table of Contents';

const fullClassList = [
    'table-of-contents',
    '||',
    classList,
];
---

{asToggle ? (
    <ToggleComponent
        {...toggleProps}
        id={id}
        heading={heading}
        class:list={fullClassList}
        displayHeading={displayHeading}
        defaultOpen={defaultOpen}
        tag="nav"
    >
        <Fragment slot="button" set:html={headingHTML} />
        <MenuList menu={nestedLists} />
    </ToggleComponent>
) : (
    <Heading
        id={headingID}
        heading={heading}
        displayHeading={displayHeading }
        set:html={headingHTML}
    />
    <section
        {...attributes}
        aria-labelledby={headingID}
        id={id}
        class:list={fullClassList}
    >
        <MenuList menu={nestedLists} />
    </section>
)}


