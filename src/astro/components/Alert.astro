---
/**
 * @since 0.1.0-alpha
 *
 * @packageDocumentation
 */

/* import - types */
import type { ComponentProps } from 'astro/types';
import type { GenericElementProps } from '../../ts/types/index.js';
import type { AlertIconProps } from './Alert_Icon.astro';

/* import - functions */

/* import - values */

/* import - components */
import Alert_Icon from './Alert_Icon.astro';
import Heading from './Heading.astro';

/* import - layouts */

/* TYPES ===================================== */

/**
 * Input props for the Alert component.
 *
 * @since 0.1.0-alpha
 * @since 0.1.0-alpha.17 — Moved to component file and renamed to AlertProps.
 */
export type AlertProps<T_IconProps extends AlertIconProps> = T_IconProps & {
    heading?: number;
};

/* PROPS ===================================== */

// prettier-ignore
export type Props<T_IconProps extends AlertIconProps = AlertIconProps> = GenericElementProps<AlertProps<T_IconProps>, 'section'>;

const {
    heading,
    slug,
    svg,
    svgLabel,
    type = 'star',
    class: classList = [],
    ...attributes
}: Props = Astro.props;

/* CONSTANTS ===================================== */

const iconProps = {
    slug,
    svg,
    svgLabel,
    type,
} as ComponentProps<typeof Alert_Icon>;

const headlineHTML = (await Astro.slots.render('headline'))?.trim() || false;

const HeadlineTag = heading ? Heading : ('header' as const);
---

<section
    {...attributes}
    class:list={[
        'alert-block',
        `alert-block--${slug ?? type}`,
        '||',
        classList,
    ]}
>
    {
        !headlineHTML ? (
            <Alert_Icon {...iconProps}>
                <slot name='icon' />
            </Alert_Icon>
        ) : (
            <HeadlineTag
                heading={heading as number}
                class='alert-block__headline'
            >
                <Alert_Icon {...iconProps}>
                    <slot name='icon' />
                </Alert_Icon>
                <Fragment set:html={headlineHTML} />
            </HeadlineTag>
        )
    }
    <slot />
</section>
