        </ToggleComponent> : ''
    ) ) }</Fragment>
) }

<p>Ut vel leo in ligula facilisis sodales. Nulla facilisi. Nullam non nibh laoreet, cursus ex ut, blandit velit. Ut sit amet tempus velit.{ ifDisplay.textPage && ' Nunc lacus erat, fermentum eget efficitur id, porttitor ultricies mi.' }<a id={tableOfContentsIds.lists.id}></a></p>

<Lists ifDisplay={ifDisplay} />

<p>Donec quam erat, sagittis id diam a, hendrerit viverra ligula. Praesent condimentum erat et egestas venenatis.{ ifDisplay.textPage && ' Donec commodo porta nibh, ac tempus turpis pulvinar id.' }</p>

<slot name="two" />

<Heading
    displayHeading={1 + displayHeading}
    heading={ 1 + heading }
>Praesent Blandit <a href="#">ex</a></Heading>
<p>Turpis maximus posuere rhoncus, nunc est aliquam ligula, non ultrices felis turpis in sapien. Proin efficitur rhoncus ex auctor faucibus. Maecenas sed ornare ante, vitae consequat tellus. Aliquam eget facilisis nunc.</p>
<p>Mauris in arcu sagittis velit aliquam cursus dignissim at odio.</p>

{ ifDisplay.buttons && (
