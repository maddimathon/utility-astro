    <p>Vivamus facilisis vitae sapien sit amet blandit. In ac justo mollis, pulvinar leo nec, efficitur tortor. Praesent molestie dolor id tellus finibus, a placerat elit faucibus.</p>
) }

{ ifDisplay.headingsList && (
    <hr />
    <Lorsum_Heading
        class="page-title"
        heading={1}
        id={tableOfContentsIds.headings?.id}
        prefix="Title (.page-title)"
    />
    <Fragment>{ ifDisplay.headingLevels.map( num => <Lorsum_Heading heading={num} /> ) }</Fragment>
) }

{ ifDisplay.headingSubtitlesList && (
    <hr />
    <Lorsum_Heading
        class="page-title"
        heading={1}
        id={tableOfContentsIds.headingSubtitles?.id}
        prefix="Title (.page-title)"
        subheading={true}
    />
    <Fragment>{ ifDisplay.textPage && (
        <p>Praesent rutrum velit sodales ante varius convallis. Pellentesque bibendum fermentum lacus. Quisque venenatis ligula metus, quis finibus arcu interdum eget.</p>
    ) }</Fragment>

    <Fragment>{ ifDisplay.headingLevels.map(
        num => (
            <Lorsum_Heading heading={num} subheading={true} />
