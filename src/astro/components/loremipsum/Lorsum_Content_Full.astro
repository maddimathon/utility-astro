    </ToggleComponent>
    
    <ToggleComponent
        {...toggleProps}
        id={`${tableOfContentsIds.toggles.id}-open-default`}
        defaultOpen={true}
    >
        <Fragment slot='button'>I am open by default</Fragment>
        <p>Boo!</p>
    </ToggleComponent>

    <Fragment>{ ifDisplay.headingLevels.map( (heading) => ( 
        tableOfContentsIds.toggles ? <ToggleComponent
            {...toggleProps}
            displayHeading={heading}
            heading={0}
            id={`${tableOfContentsIds.toggles.id}-heading${heading}`}
        >
            <Fragment
                slot='button'
                set:text={`Toggle Heading ${heading}`}
