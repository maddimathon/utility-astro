---
/**
 * @since ___PKG_VERSION___
 *
 * @packageDocumentation
 */

/* import - types */
import type {
    getLoremIpsumIds,
    LoremIpsum_DisplaySettings_Parsed,
    LoremIpsumProps,
} from '../../functions/loremIpsum.js';

/* import - functions */
import {
    getLoremIpsumToc,
} from '../../functions/loremIpsum.js';

/* import - values */

/* import - components */
import CodeBlock from '../CodeBlock.astro';
import Heading from '../Heading.astro';
import TableOfContents from '../TableOfContents.astro';

import Lorsum_Heading from './Lorsum_Heading.astro';

/* import - layouts */

/* TYPES ===================================== */

/* PROPS ===================================== */

 interface Props extends Pick<Required<LoremIpsumProps>, 'displayHeading'|'heading'|'ToggleComponent'|'toggleProps'> {
    ifDisplay: LoremIpsum_DisplaySettings_Parsed;
    previewComponents: Required<Required<LoremIpsumProps>['previewComponents']>;
    props: LoremIpsumProps;
    tableOfContentsIds: ReturnType<typeof getLoremIpsumIds>;
}

const {
    heading,
    displayHeading = heading,
    ifDisplay,
    previewComponents: { Forms, Lists, Table },
    props,
    tableOfContentsIds,
    ToggleComponent,
    toggleProps,
}: Props = Astro.props;

/* CONSTANTS ===================================== */

export const code = {
    css: [
        'body {',
        '    display: grid;',
        '    position: relative;',
        '',
        '    grid-template-columns: var(--gap-inline-layout-half, 4vw) [site-start] 0 [page-start] 1fr [sidebar-start] 0 [content-start] minmax(auto, var(--width-content, 36rem)) [content-end] 0 [sidebar-end] 1fr [page-end] 0 [site-end] var(--gap-inline-layout-half, 4vw);',
        '    grid-auto-rows: auto;',
        '    grid-auto-flow: column;',
        '',
        '    justify-content: center;',
        '    justify-items: stretch;',
        '    align-content: start;',
        '    align-items: start;',
        '',
        '    gap: 0;',
        '',
        '    margin-inline: 0;',
        '}',
    ].join('\n'),

    html: [
        '<p class="title">Title Maecenas Facilisis Sollicitudin Nisi, Eget Pellentesque Dui Rhoncus Condimentum</p>',
        '<p class="h1">Heading 1 Maecenas Facilisis Sollicitudin Nisi, Eget Pellentesque Dui Rhoncus Condimentum</p>',
        '<p class="h2">Heading 2 Maecenas Facilisis Sollicitudin Nisi, Eget Pellentesque Dui Rhoncus Condimentum</p>',
        '<p class="h3">Heading 3 Maecenas Facilisis Sollicitudin Nisi, Eget Pellentesque Dui Rhoncus Condimentum</p>',
        '<p class="h4">Heading 4 Maecenas Facilisis Sollicitudin Nisi, Eget Pellentesque Dui Rhoncus Condimentum</p>',
        '<p class="h5">Heading 5 Maecenas Facilisis Sollicitudin Nisi, Eget Pellentesque Dui Rhoncus Condimentum</p>',
        '<p class="h6">Heading 6 Maecenas Facilisis Sollicitudin Nisi, Eget Pellentesque Dui Rhoncus Condimentum</p>',
        '<p class="h7">Heading 7 Maecenas Facilisis Sollicitudin Nisi, Eget Pellentesque Dui Rhoncus Condimentum</p>',
        '<p class="h8">Heading 8 Maecenas Facilisis Sollicitudin Nisi, Eget Pellentesque Dui Rhoncus Condimentum</p>',
    ].join('\n'),

    php: [
        '$say_hi = true;',
        '',
        'if ( $say_hi ) {',
        "    echo 'Hello World!';",
        '}',
    ].join('\n'),
};

const tocMenu = ifDisplay.toc && getLoremIpsumToc( props, tableOfContentsIds, ifDisplay );
---

{ tocMenu && (
    <TableOfContents
        class="sidebar-width"
        defaultOpen={ifDisplay.tocDefaultOpen}
        displayHeading={ifDisplay.tocDisplayHeading}
        heading={heading}
        menu={tocMenu}
        ToggleComponent={ToggleComponent}
    />
) }

<p>Lorem ipsum <a href="#" target="_blank">dolor sit amet</a>, consectetur adipiscing elit. Sed vel odio at nibh <abbr title="these aren’t real words">pharetra condimentum</abbr>. <em>Nam tincidunt dapibus purus, nec tempus mi tempor vitae.</em> Mauris id sapien sodales, dignissim tortor eget, volutpat turpis.{ ifDisplay.textMedium ? <span> Donec mi ex, venenatis in elit vitae, <a href="#" aria-disabled="true">blandit sodales nunc</a>. <strong><em>Nunc pellentesque</em></strong> urna sed metus vulputate, vel maximus magna consectetur.</span> : '' }{ ifDisplay.textLong ? <span> In hac habitasse platea dictumst. Nulla aliquet iaculis dignissim. Donec pulvinar euismod ex quis imperdiet. Donec bibendum, <strong>sem id ullamcorper</strong> vehicula, ligula ante mattis nisl, ut scelerisque tortor tortor sit amet quam. Praesent lacinia elementum erat et feugiat.</span> : '' }</p>

{ ifDisplay.textPage && (
