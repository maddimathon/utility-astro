---
/**
 * @since 0.1.0-alpha
 *
 * @packageDocumentation
 */

/* import - types */
import type { GenericProps } from '../../ts/types/index.js';

import type {
    ContentType,
    DefaultContentType,
    ContentProps,
    ContentProps_Full,
} from './Content.d.ts';

/* import - functions */
import { mergeArgs } from '@maddimathon/utility-typescript';

/* import - values */

/* import - components */
import { Heading } from '../components.ts';

import Content_ExtraWide from './content/Content_ExtraWide.astro';
import Content_FullWidth from './content/Content_FullWidth.astro';
import Content_Only from './content/Content_Only.astro';
import Content_Sidebar from './content/Content_Sidebar.astro';

/* import - layouts */

/* TYPES ===================================== */

export type * from './Content.d.ts';

/* PROPS ===================================== */

// prettier-ignore
type Props<T_Type extends ContentType = DefaultContentType> = GenericProps<ContentProps<T_Type>>;

const _defProps: ContentProps_Full<ContentType> &
    Pick<Required<Props>, 'type'> = {
    type: 'content-only',

    title: undefined,
    subtitle: undefined,

    attrs: {
        main: {},
        sidebar: {},
    },
};

const { type = 'content-only', ...p } = mergeArgs(
    _defProps,
    Astro.props.frontmatter ?? Astro.props,
    true,
);

/* CONSTANTS ===================================== */

const title = Array.isArray(p.title)
    ? p.title.length
        ? p.title
        : []
    : p.title?.length
      ? [p.title]
      : [];

const titleString = title.reverse().join(' / ');

/**
 * @since ___PKG_VERSION___ — Added to exports.
 */
const contentTypes = {
    'content-only': Content_Only,
    'full-width': Content_FullWidth,
    'extra-wide': Content_ExtraWide,
    'sidebar-left': Content_Sidebar,
    'sidebar-right': Content_Sidebar,
} as const satisfies {
    [K in ContentType]: (
        result: any,
        props: ContentProps_Full<K>,
        slots?: any,
    ) => any;
};

const ContentComponent = contentTypes[type];
---

<ContentComponent {...{ ...p, type }}>
    {
        titleString ? (
            <Heading
                slot='content-header'
                attrs={{ subheading: { class: 'page-title__subheading' } }}
                class='page-title'
                heading={1}
                minimum={1}
            >
                <Fragment set:text={titleString} />
                <Fragment
                    slot='subheading'
                    set:text={p.subtitle}
                />
            </Heading>
        ) : (
            p.subtitle && (
                <p
                    slot='content-header'
                    class='page-title__subheading'
                    set:text={p.subtitle}
                />
            )
        )
    }

    <slot
        slot='content-header'
        name='content-header'
    />
    <slot
        slot='before-main-content'
        name='before-main-content'
    />
    <slot />
    <slot
        slot='after-main-content'
        name='after-main-content'
    />
    <slot
        slot='sidebar'
        name='sidebar'
    />
</ContentComponent>
