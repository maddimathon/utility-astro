{
    "name": "@maddimathon/utility-astro",
    "version": "0.1.0-beta.0",

    "author": "Maddi Mathon (www.maddimathon.com)",
    "description": "Astro utilities to use in a variety of projects.",
    
    "keywords": [
        "astro-library",
        "astro-utilities",
        "astro-utility",
        "npm-package",
        "npm-package-astro"
    ],

    "homepage": "https://maddimathon.github.io/utility-astro",
    "license": "MIT",

    "repository": {
        "type": "git",
        "url": "https://github.com/maddimathon/utility-astro.git"
    },
    
    "engines": {
        "node": ">=22"
    },

    "type": "module",

    "files": [
        "./dist/**/*",
        "./LICENSE.md",
        "./jest.config.js",
        "./package-lock.json",
        "./package.json",
        "./README.md",
        "./tsconfig.json"
    ],

    "main": "./dist/ts/index.js",
    "types": "./dist/ts/index.d.ts",

    "bugs": {
        "url": "https://github.com/maddimathon/utility-astro/issues"
    },
    
    "exports": {

        ".": {
            "sass": "./dist/scss/lib/index.scss",
            "types": "./dist/ts/index.d.ts",
            "default": "./dist/ts/index.js"
        },

        "./jest.config.js": "./jest.config.js",
        "./package.json": "./package.json",
        
        "./tsconfig": "./tsconfig.base.json",
        "./tsconfig.json": "./tsconfig.base.json",
        
        "./components": "./dist/astro/components.ts",
        "./components/*": "./dist/astro/components/*.astro",

        "./css/*": "./dist/astro/css/*.css",
        
        "./layouts": "./dist/astro/layouts.ts",
        "./layouts/*": "./dist/astro/layouts/*.astro",
        
        "./support": "./dist/astro/support.ts",
        "./support/*": "./dist/astro/support/*.astro",

        "./functions": "./dist/astro/functions.ts",

        "./astro/*": [
            "./dist/astro/*.astro",
            "./dist/astro/*.js",
            "./dist/astro/*/index.js",
            "./dist/astro/*"
        ],
        
        
        "./config.scss": "./dist/scss/config/index.scss",
        "./config/*.scss": [
            "./dist/scss/config/*.scss",
            "./dist/scss/config/_*.scss",
            "./dist/scss/config/*/index.scss",
            "./dist/scss/config/*/_index.scss"
        ],

        "./notice.scss": "./dist/scss/_notice.scss",
        
        "./template.scss": "./dist/scss/template/default/index.scss",

        "./template/config.scss": "./dist/scss/template/_content/config/utility-sass/_index.scss",
        "./template/config/*.scss": [
            "./dist/scss/template/_content/config/template/*.scss",
            "./dist/scss/template/_content/config/template/_*.scss",
            "./dist/scss/template/_content/config/template/*/index.scss",
            "./dist/scss/template/_content/config/template/*/_index.scss"
        ],
        
        "./template/lib.scss": "./dist/scss/template/_content/lib/_index.scss",

        "./template/content.scss": "./dist/scss/template/_content/_index.scss",
        "./template/content/notice.scss": "./dist/scss/template/_content/_header/_notice.scss",

        "./template/content/abstracts.scss": "./dist/scss/template/_content/_00-abstracts.scss",
        "./template/content/components.scss": "./dist/scss/template/_content/04-components/_index.scss",
        "./template/content/globals.scss": "./dist/scss/template/_content/01-globals/_index.scss",
        "./template/content/layouts.scss": "./dist/scss/template/_content/02-layouts/_index.scss",
        "./template/content/utilities.scss": "./dist/scss/template/_content/03-utilities/_index.scss",
        
        "./template/*.scss": [
            "./dist/scss/template/*.scss",
            "./dist/scss/template/_*.scss",
            "./dist/scss/template/*/index.scss",
            "./dist/scss/template/*/_index.scss"
        ],

        "./tokens.scss": "./dist/scss/tokens/index.scss",
        "./tokens/*.scss": [
            "./dist/scss/tokens/*.scss",
            "./dist/scss/tokens/_*.scss",
            "./dist/scss/tokens/*/index.scss",
            "./dist/scss/tokens/*/_index.scss"
        ],

        "./*.scss": [
            "./dist/scss/lib/*.scss",
            "./dist/scss/lib/_*.scss",
            "./dist/scss/lib/*/index.scss",
            "./dist/scss/lib/*/_index.scss",
            "./dist/scss/*/index.scss",
            "./dist/scss/*/_index.scss",
            "./dist/scss/*.scss",
            "./dist/scss/_*.scss"
        ],

        "./*": {
            
            "sass": [
                "./dist/scss/lib/*.scss",
                "./dist/scss/lib/_*.scss",
                "./dist/scss/lib/*/index.scss",
                "./dist/scss/lib/*/_index.scss",
                "./dist/scss/*/index.scss",
                "./dist/scss/*/_index.scss",
                "./dist/scss/lib/*",
                "./dist/scss/lib/_*",
                "./dist/scss/*",
                "./dist/scss/_*"
            ],

            "types": [
                "./dist/ts/*.d.ts",
                "./dist/ts/*/index.d.ts",
                "./dist/ts/*"
            ],

            "default": [
                "./dist/ts/*.js",
                "./dist/ts/*/index.js",
                "./dist/ts/*"
            ]
        }
    },

    "scripts": {
        "unlink": "run-p unlink:*",
            "unlink-ts":    "rm -rf node_modules/@maddimathon/utility-typescript || echo ''",
            "unlink-build": "rm -rf node_modules/@maddimathon/build-utilities || echo ''",
            "unlink:sass":  "rm -rf node_modules/@maddimathon/utility-sass || echo ''",

        "link": "run-p link:*",
            "link-ts":    "npm run unlink-ts    && mkdir -p node_modules/@maddimathon/utility-typescript  && cp -R -H -f -p ../utility-typescript/package.json ../utility-typescript/dist node_modules/@maddimathon/utility-typescript", 
            "link-build": "npm run unlink-build && mkdir -p node_modules/@maddimathon/build-utilities     && cp -R -H -f -p ../npm-build-utilities/package.json ../npm-build-utilities/tsconfig.base.json ../npm-build-utilities/tsconfig.scripts.json ../npm-build-utilities/dist node_modules/@maddimathon/build-utilities",
            "link:sass":  "npm run unlink:sass  && mkdir -p node_modules/@maddimathon/utility-sass        && cp -R -H -f -p ../utility-sass/package.json ../utility-sass/dist node_modules/@maddimathon/utility-sass",

        "preinstall": "npm run unlink",

        "commit": "sh .scripts/commit.sh",

        "rm": "rm -rf dist docs src/astro/css",

        "astro:check": "astro check",
        "astro:build": "astro check && astro build",
        "astro:preview": "astro preview",
        "astro:start": "astro dev --verbose",

        "preview": "astro preview",
        

        "watch": "run-p watch:* start:*",
            "watch:astro":     "watch -p 'src/astro/**/*'                                                                        -c 'build-utils build --without minimize,readme,document --only-compile astro --watchedWatcher \"astro\"     --watchedChange --watchedFilename \"$FILENAME\" --watchedEvent \"$EVENT\"'",
            "watch:scss":      "watch -p 'src/scss/**/*'                         -p 'node_modules/@maddimathon/*/dist/scss/**/*' -c 'build-utils build --without minimize,readme,document --only-compile scss  --watchedWatcher \"scss\"      --watchedChange --watchedFilename \"$FILENAME\" --watchedEvent \"$EVENT\"'",
            "watch:docs-scss": "watch -p 'src/scss/**/*' -p 'src/docs/scss/**/*' -p 'node_modules/@maddimathon/*/dist/scss/**/*' -c 'build-utils build --without minimize,readme,compile  --only-document scss --watchedWatcher \"docs-scss\" --watchedChange --watchedFilename \"$FILENAME\" --watchedEvent \"$EVENT\"'",
            "watch:ts":        "watch -p 'src/ts/**/*'                                                                           -c 'build-utils build --without minimize,readme,document --only-compile ts    --watchedWatcher \"ts\"        --watchedChange --watchedFilename \"$FILENAME\" --watchedEvent \"$EVENT\"'",
        
        
        "build-start": "build-utils build --starting && npm run start",

        "start": "run-p watch:docs-scss watch:scss watch:ts s-watch:* start:*",
            "s-watch:typedoc": "watch -p 'src/ts/**/*'   -p 'src/astro/**/*'                                                                                                                  -c 'build-utils build --without minimize,readme,compile  --only-document typedoc --watchedWatcher \"typedoc\" --watchedChange --watchedFilename \"$FILENAME\" --watchedEvent \"$EVENT\"'",
            "start:astro": "astro dev",


        "snap":     "build-utils snapshot",
        "snapshot": "build-utils snapshot",

        "compile": "build-utils compile",

        "test": "build-utils test",

        "doc":      "build-utils document",
        "document": "build-utils document",

        "build":       "build-utils build",
        "quick-build": "build-utils build -- --without minimize,prettify",

        "package": "build-utils package",
        "dryrun": "build-utils release --dryrun --without-package snapshot,zip",

        "release": "build-utils release"
    },
    
    "dependencies": {
        "@astrojs/prism": "^3.3.0",
        "@maddimathon/utility-sass": "~0.1.0-alpha.41",
        "@maddimathon/utility-typescript": "~2.0.0-beta.3",
        "astro": "^5.17.3",
        "luxon": "^3.7.2"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.8",
        "@astrojs/ts-plugin": "^1.10.7",
        "@maddimathon/build-utilities": "~0.3.0-alpha.18",
        "@types/jest": "~30.0.0",
        "@types/luxon": "~3.7.1",
        "@types/node": "22.15.30",
        "jest": "~30.2.0",
        "npm-run-all": "~4.1.5",
        "typedoc": "~0.28.19",
        "typedoc-plugin-inline-sources": "~1.3.0",
        "typedoc-plugin-markdown": "~4.11.0",
        "typescript": "~5.9.3",
        "watch-cli": "~0.2.3"
    },
    
    "peerDependencies": {
        "@astrojs/prism": "^3.3.0",
        "@maddimathon/utility-sass": "~0.1.0-beta.0",
        "@maddimathon/utility-typescript": "~2.0.0-beta.3",
        "astro": "^5.16.0"
    },
    "peerDependenciesMeta": {
        "@astrojs/prism": {
            "optional": true
        }
    },

    "browserslist": [
        "last 3 major versions",
        "> 0.5%",
        "not dead"
    ]
}
