---
/**
 *
 *
 * @package boilerplate-astro-project@0.1.0-beta.0.draft
 * @since 0.1.0-alpha
 */

/* import - types */

import type { PartialExcept } from '@maddimathon/utility-typescript/types';

import type { GenericProps } from '../../ts/index.ts';

import type { NavMenuProps } from '../components/NavMenu.astro';

import type { ContentProps, ContentType } from './Content.astro';

import type { PageProps } from './Page.d.ts';

/* import - functions */
import { DateTime } from 'luxon';
import { mergeArgs, slugify } from '@maddimathon/utility-typescript';
import { FeatureCheck } from '@maddimathon/utility-sass';

import { mapToObject } from '../../ts/functions/mapToObject.js';
import { currentPagePath, makeClassList } from '../functions.js';

/* import - values */

/* import - layouts */
import Content from './Content.astro';

/* import - components */
import {
    NavMenu,
    Page_Meta,
    SettingsMenu,
    SkipLinks,
    ToggleNavMenu,
} from '../components.ts';
import RenderedSlotContent from '../components/RenderedSlotContent.astro';

/** ## TYPES ==================================== **/

export type * from './Page.d.ts';

/** ## PROPS ==================================== **/

type Props<T_ContentType extends ContentType = ContentType> = GenericProps<
    PageProps<T_ContentType>
>;

const p = Astro.props.frontmatter ?? Astro.props;

const {
    PrimaryMenu = ToggleNavMenu,
    SettingsMenu: SettingsMenuComponent = SettingsMenu,
} = p.components ?? {};

/* ### Content Props ------------------ */

const content = {
    ...p.content,

    subtitle: p.subtitle,

    title: Array.isArray(p.title)
        ? p.title.length
            ? p.title
            : []
        : p.title.length
          ? [p.title]
          : [],

    type: p.layout,
} satisfies ContentProps<ContentType>;

/** ## CONSTANTS ==================================== **/

const pageSlug: string =
    slugify(currentPagePath(Astro.url).replace(/\.(html|php)$/gi, '')) ||
    'home';

const SiteTitleTag = content.title && content.title.length ? 'p' : 'h1';

/* ### Nav Menus ------------------ */

/**
 * The menu params constructed from input props.
 */
const menus: {
    primary?: NavMenuProps;
    secondary?: NavMenuProps;
} = {};

if (p.primaryMenu) {
    let _menu: PartialExcept<NavMenuProps, 'menu'>;

    if (Array.isArray(p.primaryMenu)) {
        _menu = {
            menu: p.primaryMenu,
        };
    } else {
        _menu = p.primaryMenu;
    }

    menus.primary = {
        'aria-label': 'Primary Menu',
        'id': 'primary-menu',
        ..._menu,
        'convertHrefStringsToAbsolute': p.convertHrefStringsToAbsolute,
    };
}

if (p.secondaryMenu) {
    let _menu: PartialExcept<NavMenuProps, 'menu'>;

    if (Array.isArray(p.secondaryMenu)) {
        _menu = {
            menu: p.secondaryMenu,
        };
    } else {
        _menu = p.secondaryMenu;
    }

    menus.secondary = {
        'aria-label': 'Secondary Menu',
        'id': 'secondary-menu',
        ..._menu,
        'convertHrefStringsToAbsolute': p.convertHrefStringsToAbsolute,
    };
}

/* ### Support ------------------ */

const scripts = mergeArgs(
    {
        featureCheck: true,
    },
    p.scripts,
);

/* ### Slots ------------------ */

/**
 * Rendered slot HTML.
 */
const slots_render = mapToObject(
    await Promise.all(
        (
            [
                'afterFooter',
                'afterHeader',
                'afterPrimaryNav',
                'afterSecondaryNav',
                'beforeFooter',
                'beforeHeader',
                'beforePrimaryNav',
                'beforeSecondaryNav',
                'bodyClose',
                'bodyOpen',
                'footer',
                'footerScripts',
                'headClose',
                'header',
                'headOpen',
            ] as const
        ).map(async (_key) => {
            const _kebab = _key.replace(
                /([a-z0-9])([A-Z])/g,
                (_v, _cap1, _cap2) => _cap1 + '-' + _cap2.toLowerCase(),
            );

            return [
                _key,
                Astro.slots.has(_kebab) &&
                    (await Astro.slots.render(_kebab))?.trim(),
            ] as const;
        }),
    ),
);

/* ### Include ------------------ */

/**
 * Sections/components to include or not.
 */
const include = {
    footer:
        p.footer &&
        (p.footer.copyright || p.footer.designedBy || slots_render.footer),

    header:
        p.header && (p.header.title || p.header.tagline || slots_render.header),
};

/* ### Preformatted ------------------ */

const today = DateTime.now();

const _footerCopyrightYear = p.footer?.copyright
    ? (p.footer.copyright.year ?? today.year)
    : null;

/**
 * Some formatted text strings to use below.
 */
const formatted = {
    footer: {
        year:
            _footerCopyrightYear && today.year > _footerCopyrightYear
                ? `${_footerCopyrightYear}–${today.year}`
                : _footerCopyrightYear,
    },
};

/* ### FeatureCheck ------------------ */

const featureClasses = scripts.featureCheck
    ? FeatureCheck.DEFAULT_CLASSLIST()
    : [];

/* ### Settings ------------------ */

const settings = p.settings && {
    ...(p.settings === true ? {} : p.settings),
    accessibilityReportEmail: p.accessibilityReportEmail,
    privacyPolicy: p.privacyPolicy,
};
---

<html
    {...p.attrs?.html ?? {}}
    lang={p.lang}
    dir={p.dir ?? 'auto'}
    class:list={[featureClasses, p.attrs?.html?.class]}
>
    <!-- 
        This page includes html generated using
        @maddimathon/utility-astro@0.1.0-beta.0.draft

        Author: Maddi Mathon (https://www.maddimathon.com/web)
        License: MIT
    -->
    <head>
        <meta charset='UTF-8' />
        <meta name='viewport' content='width=device-width,initial-scale=1' />
        { p.lang && <meta property='og:locale' content={p.lang} /> }
        <RenderedSlotContent
            name='head-open'
            html={slots_render.headOpen}
        />
        <Page_Meta {...p.meta} />
        <RenderedSlotContent
            name='head-close'
            html={slots_render.headClose}
        />
    </head>

    <body
        {...p.attrs?.body ?? {}}
        class:list={makeClassList([
            `page_${pageSlug}`,
            content.type && `layout_${slugify(content.type)}`,
        ], p.attrs?.body?.class ?? [])}
    >
        {p.skipLinks && <SkipLinks links={p.skipLinks} />}

        <RenderedSlotContent
            name='body-open'
            html={slots_render.bodyOpen}
        />

        {
            settings && (
                <SettingsMenuComponent {...settings}>
                    <slot
                        name='settings-menu-open'
                        slot='settings-menu-open'
                    />
                    <slot name='settings-menu' />
                    <slot
                        name='settings-menu-close'
                        slot='settings-menu-close'
                    />
                </SettingsMenuComponent>
            )
        }

        <RenderedSlotContent
            name='before-header'
            html={slots_render.beforeHeader}
        />

        {
            include.header && (
                <header class='site-header'>
                    {p.header?.title && (
                        <SiteTitleTag
                            class='site-title'
                            set:text={p.header.title}
                        />
                    )}
                    {p.header?.tagline && (
                        <p
                            class='site-tagline'
                            set:text={p.header.tagline}
                        />
                    )}

                    <RenderedSlotContent
                        name='header'
                        html={slots_render.header}
                    />
                </header>
            )
        }

        {
            menus.primary && menus.primary.menu.length > 0 && (
                <RenderedSlotContent
                    name='before-primary-nav'
                    html={slots_render.beforePrimaryNav}
                />
                <PrimaryMenu
                    {...menus.primary}
                    class:list='nav-primary'
                />
                <RenderedSlotContent
                    name='after-primary-nav'
                    html={slots_render.afterPrimaryNav}
                />
            )
        }

        <RenderedSlotContent
            name='after-header'
            html={slots_render.afterHeader}
        />

        <Content {...content}>
            <slot
                slot='content-header'
                name='content-header'
            />
            <slot
                slot='before-main-content'
                name='before-main-content'
            />
            <slot />
            <slot
                slot='after-main-content'
                name='after-main-content'
            />
            <slot
                slot='sidebar'
                name='sidebar'
            />
        </Content>

        {
            menus.secondary && menus.secondary.menu.length > 0 && (
                <RenderedSlotContent
                    name='before-secondary-nav'
                    html={slots_render.beforeSecondaryNav}
                />
                <NavMenu
                    {...menus.secondary}
                    class:list='nav-secondary'
                />
                <RenderedSlotContent
                    name='after-secondary-nav'
                    html={slots_render.afterSecondaryNav}
                />
            )
        }

        <RenderedSlotContent
            name='before-footer'
            html={slots_render.beforeFooter}
        />

        {
            p.footer && include.footer && (
                <footer class='site-footer'>
                    <RenderedSlotContent
                        name='footer'
                        html={slots_render.footer}
                    />

                    {(p.footer.designedBy || p.footer.copyright) && (
                        <div class='site-footer__disclaimer'>
                            {p.footer.copyright && (
                                <p class='copyright'>
                                    <span class='copyright__copy'>&copy;</span>
                                    <Fragment
                                        set:text={' ' + formatted.footer.year + ' '}
                                    />
                                    {p.footer.copyright.owner ? <Fragment
                                        set:text={p.footer.copyright.owner}
                                    /> : <Fragment
                                        set:html={p.footer.copyright.html}
                                    />}
                                </p>
                            )}
                            {p.footer.designedBy && <Fragment set:html={p.footer.designedBy} />}
                        </div>
                    )}
                </footer>
            )
        }

        <RenderedSlotContent
            name='after-footer'
            html={slots_render.afterFooter}
        />
        <RenderedSlotContent
            name='body-close'
            html={slots_render.bodyClose}
        />
        <RenderedSlotContent
            name='footer-scripts'
            html={slots_render.footerScripts}
        />
    </body>
</html>

<script src='../scripts/feature-check-init.ts'></script>
