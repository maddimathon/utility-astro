---
/**
 * @since 0.1.0-alpha
 *
 * @packageDocumentation
 */

/* import - types */
import type { GenericElementProps } from '../../ts/types/index.js';
import RenderedSlotContent from '../components/RenderedSlotContent.astro';

/* import - functions */

/* import - values */

/* import - components */

/* import - layouts */

/* TYPES ===================================== */

/**
 * Input props for the Sidebar component.
 *
 * @since 0.1.0-alpha
 */
export interface SidebarProps {}

/* PROPS ===================================== */

type Props = GenericElementProps<SidebarProps, 'aside'>;

const { class: classList = [], ...attributes }: Props =
    Astro.props.frontmatter ?? Astro.props;

/* CONSTANTS ===================================== */

const rendered =
    Astro.slots.has('default') && (await Astro.slots.render('default'))?.trim();
---

<aside
    role='complementary'
    id='sidebar'
    class:list={['site-sidebar', '||', classList]}
    {...attributes}
>
    <RenderedSlotContent
        name='sidebar'
        html={rendered}
        ><p
            slot='empty-before'
            class='screen-reader-text'
        >
            This sidebar is empty, sorry!
        </p></RenderedSlotContent
    >
</aside>

<style lang='scss'>
    @forward '../css/screen-reader-text.css';
</style>
