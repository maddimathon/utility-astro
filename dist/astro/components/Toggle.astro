---
/**
 * @since 0.1.0-alpha
 *
 * @packageDocumentation
 */

/* import - types */
import type { ElementProps } from '../../ts/types/index.js';

/* import - functions */
import Toggle_Scripts from '../support/Toggle_Scripts.astro';

/* import - values */

/* import - components */
import Heading from './Heading.astro';
import Toggle_Control from '../support/Toggle_Control.astro';

/* import - layouts */

/* PROPS ===================================== */

/**
 * Input props for the Toggle component.
 *
 * @since 0.1.0-alpha
 */
export interface ToggleProps {
    children: any; // these are the slots

    /**
     * Unique id attr.
     */
    id: string;

    class?: string;

    defaultOpen?: boolean;

    /**
     * If any, the heading display level override for this heading (otherwise
     * the `heading` value is used).
     *
     * @default undefined
     *
     * @since 0.1.0-alpha.7 — Added false and undefined options.
     * @since 0.1.0-beta.0.draft — Removed false as an option. Use 0 instead.
     */
    displayHeading?: number | undefined;

    /**
     * If any, the heading level used to wrap the toggle button.
     *
     * @default 0
     *
     * @since 0.1.0-beta.0.draft — Removed false as an option. Use 0 instead.
     */
    heading?: number;

    /**
     * Minimum allowed heading level.
     *
     * @default 2
     *
     * @since 0.1.0-beta.0.draft
     */
    minimumHeading?: number;

    /**
     * The HTML tag used for the container element.
     *
     * @default 'section'
     *
     * @since 0.1.0-alpha.7
     */
    tag?: undefined | 'div' | 'li' | 'nav' | 'section';

    /**
     * The HTML tag used for the container's header element. If tag is
     * 'section', default is 'header', else it is 'div'.
     *
     * @since 0.1.0-alpha.7
     */
    headerTag?: undefined | 'div' | 'header';
}

type Props = ElementProps<
    ToggleProps,
    'div',
    'aria-label' | 'aria-labelledby' | 'class' | 'class:list'
>;

const {
    defaultOpen,
    id,
    // optional
    displayHeading,
    heading = 0,
    headerTag,
    minimumHeading = 2,
    tag: Container = 'section',
    ...attributes
}: Props = Astro.props;

/* FUNCTIONS ===================================== */

/**
 * Functions that generate ID values for Toggle elements.
 *
 * @since 0.1.0-alpha.7
 */
export const generateID = {
    button: (_id: string) => `${_id}-button`,
    content: (_id: string) => `${_id}-content`,
    title: (_id: string) => `${_id}-title`,
};

/* CONSTANTS ===================================== */

const buttonID = generateID.button(id);
const contentID = generateID.content(id);
const titleID = generateID.title(id);

const ContainerHeader =
    headerTag ?? (Container === 'section' ? 'header' : 'div');
---

<div
    id={id}
    {...attributes}
    data-toggle-container={defaultOpen ? 'open' : 'closed'}
>
    <ContainerHeader
        id={titleID}
        class='toggle-title'
    >
        <Heading
            displayHeading={displayHeading}
            heading={heading}
            minimum={minimumHeading}
        >
            <Toggle_Control
                {...{ id, buttonID }}
                data-toggle-primary-control={id}
            >
                <slot name='button' />
            </Toggle_Control>
        </Heading>
    </ContainerHeader>

    <Container
        aria-labelledby={titleID}
        data-toggle-content={id}
        id={contentID}
    >
        <div class='container'><slot /></div>
    </Container>
</div>

<Toggle_Scripts />
