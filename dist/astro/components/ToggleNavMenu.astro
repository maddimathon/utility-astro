---
/**
 * @since 0.1.0-alpha
 *
 * @packageDocumentation
 */

/* import - types */
import type { GenericElementProps } from '../../ts/types/index.js';
import type { NavMenuProps } from './NavMenu.astro';

/* import - functions */
import { parseMenuItem } from './NavMenu.astro';

/* import - values */

/* import - components */
import MenuList from './MenuList.astro';
import Toggle_Control from '../support/Toggle_Control.astro';
import Heading from './Heading.astro';

/* import - layouts */

/* TYPES ===================================== */

/**
 * Input props for the ToggleNavMenu component.
 *
 * @since 0.1.0-alpha
 * @since 0.1.0-alpha.17 — Moved to component file.
 */
export interface ToggleNavMenuProps extends NavMenuProps {
    /**
     * @since 0.1.0-beta.0.draft
     */
    iconSVG?: string;
}

/* PROPS ===================================== */

type Props = GenericElementProps<ToggleNavMenuProps, 'div'>;

const {
    class: classList = [],
    convertHrefStringsToAbsolute,
    iconSVG,
    id: menuID,
    menu,
    ...attributes
}: Props = Astro.props.frontmatter ?? Astro.props;

/* CONSTANTS ===================================== */

const parsedMenu = menu.map((_item) =>
    parseMenuItem(Astro.url, _item, convertHrefStringsToAbsolute),
);

const id = `${menuID}-toggle`;

const buttonID = `${id}-button`;
const contentID = `${id}-content`;
const titleID = `${id}-title`;

/**
 * Rendered icon HTML.
 */
const buttonHTML = (await Astro.slots.render('button'))?.trim() || 'Menu';
---

<nav
    {...attributes}
    id={id}
    data-toggle-container
    class:list={classList}
    role='navigation'
>
    <div
        id={titleID}
        class='toggle-title'
    >
        <Heading
            displayHeading={-1}
            heading={0}
        >
            <Toggle_Control
                {...{ id, buttonID }}
                class='toggle-nav-menu__button'
                data-toggle-primary-control={id}
                iconSVG={iconSVG}
            >
                <slot
                    slot='icon'
                    name='icon'
                />
                <Fragment set:html={buttonHTML} />
            </Toggle_Control>
        </Heading>
    </div>

    <div
        aria-labelledby={titleID}
        data-toggle-content={id}
        id={contentID}
    >
        <div class='container'><MenuList menu={parsedMenu} /></div>
    </div>

    <div
        data-toggle-control={id}
        data-toggle-control-backdrop={id}
        class='toggle-nav-menu__backdrop'
        aria-hidden='true'
    >
    </div>
</nav>
