/* import - types */
import type { GenericElementProps } from '../../ts/types/index.js';

/* import - functions */

/* import - values */

/* import - components */

/* import - layouts */

/* TYPES ===================================== */

// prettier-ignore
export type CopyToClipboardButtonProps = CopyToClipboardButtonProps.WithChildren | CopyToClipboardButtonProps.WithSetHtml | CopyToClipboardButtonProps.WithSetText;

export namespace CopyToClipboardButtonProps {
    type Base = {
        /**
         * Timeout length to switch the button to active state, in milliseconds.
         */
        activeTimeout?: undefined | number;

        /**
         * Timeout length to display the success message, in milliseconds.
         */
        messageTimeout?: undefined | number;

        /**
         * Content to copy to clipboard.
         */
        toClipboard: string;

        /**
         * Success message to display when copied.
         */
        successMessage?: string;
    };

    export type WithChildren = Base & {
        /**
         * Must have content to label the button (or intentionally leave it blank).
         */
        children: any;
    };

    export type WithSetHtml = Base & {
        'set:html': string;
    };

    export type WithSetText = Base & {
        'set:text': string;
    };
}

/* PROPS ===================================== */

// prettier-ignore
type Props = GenericElementProps<CopyToClipboardButtonProps.WithChildren, 'div'> | GenericElementProps<CopyToClipboardButtonProps.WithSetHtml, 'div'> | GenericElementProps<CopyToClipboardButtonProps.WithSetText, 'div'>;

const {
    activeTimeout,
    // copyAs,
    messageTimeout,
    successMessage,
    toClipboard,

    class: classListInput = [],
    ...attributes
}: Props = Astro.props.frontmatter ?? Astro.props;

/* CONSTANTS ===================================== */

const classList = [
    'button--copy-to-clipboard',
    { '||': classListInput },
    classListInput,
];

// data-copy-to-clipboard-as={copyAs}
---

<button
    {...attributes}
    class:list={classList}
    data-copy-to-clipboard={toClipboard}
    data-copy-to-clipboard-success={successMessage}
    data-copy-to-clipboard-active-timeout={activeTimeout}
    data-copy-to-clipboard-message-timeout={messageTimeout}
    ><slot /></button
><script>
    import { CopyToClipboard } from '../../ts/classes/CopyToClipboard.js';

    CopyToClipboard.run();
</script>
