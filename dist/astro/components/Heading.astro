---
/**
 * @since 0.1.0-alpha
 *
 * @packageDocumentation
 */

/* import - types */
import type { ClassList, GenericElementProps } from '../../ts/types/index.js';
import type { HTMLAttributes, HTMLTag } from 'astro/types';

/* import - functions */
import { makeNumber } from '@maddimathon/utility-typescript';
import { makeClassList } from '../functions.js';

/* import - values */

/* import - components */

/* import - layouts */

/* TYPES ===================================== */

/* PROPS ===================================== */

/**
 * Input props for the Heading component.
 *
 * @since 0.1.0-alpha
 */
export interface HeadingProps {
    /**
     * If any, the heading display level override for this heading (otherwise
     * the `heading` value is used).  If false, a 'unstyled-heading' utility
     * class is adding to the heading.
     *
     * @since 0.1.0-alpha.7 — Added false and undefined options.
     */
    displayHeading?: number | false | undefined;

    /**
     * @since 0.1.0-beta.0.draft
     */
    fallbackTag?: HTMLTag | undefined;

    /**
     * Logical heading order value for this heading.
     */
    heading?: number | undefined;

    /**
     * The minimum allowed value for this heading.
     */
    minimum?: number | undefined;

    /**
     * Additional attributes for other elements.
     */
    attrs?:
        | undefined
        | {
              hgroup?:
                  | undefined
                  | (Omit<HTMLAttributes<'hgroup'>, 'class' | 'class:list'> & {
                        class?: ClassList;
                    });
              subheading?:
                  | undefined
                  | (Omit<HTMLAttributes<'p'>, 'class' | 'class:list'> & {
                        class?: ClassList;
                    });
          };
}

type Props = GenericElementProps<HeadingProps, 'div'>;

/* FUNCTIONS ===================================== */

export function parseHeadingParams(
    html: { content: string; subheading: string },
    {
        attrs: { hgroup: attrs_hgroup, subheading: attrs_subheading } = {},
        class: classList = [],
        displayHeading: displayHeadingRaw,
        fallbackTag = 'p',
        heading: headingRaw = 0,
        minimum = 2,
        ...attributes
    }: Props,
) {
    const heading = Math.round(Number(headingRaw));

    const numDisplayHeadingRaw =
        makeNumber(displayHeadingRaw) ?? displayHeadingRaw;

    const displayHeading =
        typeof numDisplayHeadingRaw === 'number'
            ? Math.round(numDisplayHeadingRaw)
            : typeof numDisplayHeadingRaw === 'undefined'
              ? numDisplayHeadingRaw
              : -1;

    const headingIsMoreThanMinimum = heading >= Math.max(1, minimum);

    const headingClass =
        typeof displayHeading === 'undefined' || displayHeading < 0
            ? !heading
                ? ('unstyled-heading' as const)
                : heading > 6
                  ? (`h${heading}` as const)
                  : headingIsMoreThanMinimum
                    ? ('' as const)
                    : ('unstyled-heading' as const)
            : displayHeading < 1
              ? ('unstyled-heading' as const)
              : (`h${displayHeading}` as const);

    const HeadingWrapper =
        headingIsMoreThanMinimum && heading < 7
            ? (`h${heading as 1 | 2 | 3 | 4 | 5 | 6}` as const)
            : fallbackTag;

    const guaranteedHeadingClass = headingClass
        ? headingClass
        : HeadingWrapper === 'p'
          ? 'unstyled-heading'
          : HeadingWrapper;

    return {
        attrs: {
            heading: {
                ...attributes,
                'aria-level': heading > 6 ? heading : undefined,
                'class:list': makeClassList(
                    [
                        headingClass,
                        html.subheading
                            ? `${guaranteedHeadingClass}--hgroup`
                            : '',
                    ],
                    classList,
                ),
                'role': heading > 6 ? 'heading' : undefined,
            } satisfies HTMLAttributes<'p'>,

            hgroup: {
                'aria-roledescription': 'heading group',

                ...attrs_hgroup,

                'class': undefined,
                'class:list': makeClassList(
                    `${guaranteedHeadingClass}__hgroup`,
                    attrs_hgroup?.class,
                ),

                'role': 'group',
            } satisfies HTMLAttributes<'hgroup'>,

            subheading: {
                'aria-roledescription': 'subheading',

                ...attrs_subheading,

                'class': undefined,
                'class:list': makeClassList(
                    `hgroup__subheading ${guaranteedHeadingClass}__subheading`,
                    attrs_subheading?.class,
                ),
            } satisfies HTMLAttributes<'p'>,
        },

        displayHeading,
        heading,

        headingClass,
        guaranteedHeadingClass,

        HeadingWrapper,
    } as const;
}

/* CONSTANTS ===================================== */

const html = {
    content: (await Astro.slots.render('default'))?.trim(),
    subheading: (await Astro.slots.render('subheading'))?.trim(),
};

const { attrs, HeadingWrapper } = parseHeadingParams(
    html,
    Astro.props.frontmatter ?? Astro.props,
);
---

{
    html.content &&
        (html.subheading ? (
            <hgroup {...attrs.hgroup}>
                <HeadingWrapper
                    {...attrs.heading}
                    set:html={html.content}
                />
                <p
                    {...attrs.subheading}
                    set:html={html.subheading}
                />
            </hgroup>
        ) : (
            <HeadingWrapper
                {...attrs.heading}
                set:html={html.content}
            />
        ))
}
