/* import - types */
import type {
    getLoremIpsumIds,
    LoremIpsum_DisplaySettings_Parsed,
} from '../../functions/loremIpsum.js';

/* import - functions */

/* import - values */

/* import - components */
import Table from '../Table.astro';

/* import - layouts */

/* TYPES ===================================== */

/* PROPS ===================================== */

export interface Props {
    ifDisplay: LoremIpsum_DisplaySettings_Parsed;
    tableOfContentsIds: ReturnType<typeof getLoremIpsumIds>;
}

const { ifDisplay, tableOfContentsIds }: Props = Astro.props;

/* CONSTANTS ===================================== */
---

<Table id={tableOfContentsIds.table?.id}>
    <tr>
        <th scope='col'>Table Heading 1</th>
        <th scope='col'>Table Heading 2</th>
        {/* <th>Table Heading 3</th> */}
    </tr>
    <tr>
        <td>Pellentesque in mauris.</td>
        <td>Sed ullamcorper eu </td>
        {/* <td>Praesent mollis pretium.</td> */}
    </tr>
    <tr>
        <td>Quisque venenatis ac.</td>
        <td>Ut eros lacus, mattis sit.</td>
        {/* <td>Nam congue sagittis.</td> */}
    </tr>
</Table>

{
    ifDisplay.tableLong && (
        <Table>
            <tr>
                <th scope='col'>
                    <span class='screen-reader-text'>Row Headings</span>
                </th>
                <th scope='col'>Table Heading 1</th>
                <th scope='col'>Table Heading 2</th>
                <th scope='col'>Table Heading 3</th>
            </tr>
            <tr>
                <th scope='row'>Row 1</th>
                <td>
                    Pellentesque in mauris neque. Vivamus rutrum sodales eros,
                    quis cursus leo ultrices eget.
                </td>
                <td>Sed ullamcorper eu sapien vitae elementum. </td>
                <td>Praesent mollis efficitur odio vitae pretium.</td>
            </tr>
            <tr>
                <th scope='row'>Row 2</th>
                <td>Quisque venenatis ac velit venenatis scelerisque.</td>
                <td>
                    Ut eros lacus, mattis sit amet pretium a, fermentum et
                    dolor. Cras eu semper massa.
                </td>
                <td>
                    Nam congue sagittis scelerisque. Etiam et diam pharetra,
                    tempor ex sit amet, scelerisque est.
                </td>
            </tr>
        </Table>
    )
}
