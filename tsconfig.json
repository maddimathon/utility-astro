    "include": [
        "./src/**/*"
    ],
    "exclude": [
        "./.scripts/**/*",
        "./node_modules/**/*"
    ],
    "compilerOptions": {
        "isolatedDeclarations": false,

        "plugins": [
            {
              "name": "@astrojs/ts-plugin"
            }
        ]
    }
}